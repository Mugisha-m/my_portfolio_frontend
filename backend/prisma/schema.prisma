generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  EDITOR
}

enum PublishStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  UNPUBLISHED
}

enum MessageStatus {
  UNREAD
  READ
  REPLIED
  ARCHIVED
  DELETED
}

enum MediaType {
  IMAGE
  DOCUMENT
  VIDEO
  OTHER
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  name         String?
  role         Role       @default(ADMIN)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  auditLogs    AuditLog[]
}

model Project {
  id          String        @id @default(cuid())
  title       String
  slug        String        @unique
  summary     String
  description String
  caseStudy   String?
  status      PublishStatus @default(DRAFT)
  featured    Boolean       @default(false)
  githubUrl   String?
  demoUrl     String?
  coverImage  String?
  viewCount   Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  publishedAt DateTime?
  categories  Category[]    @relation("ProjectCategories")
  tags        Tag[]         @relation("ProjectTags")
  media       Media[]       @relation("ProjectMedia")
}

model Blog {
  id              String        @id @default(cuid())
  title           String
  slug            String        @unique
  excerpt         String
  content         String
  coverImage      String?
  externalUrl     String?
  status          PublishStatus @default(DRAFT)
  seoTitle        String?
  seoDescription  String?
  scheduledFor    DateTime?
  publishedAt     DateTime?
  viewCount       Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  categories      Category[]    @relation("BlogCategories")
  tags            Tag[]         @relation("BlogTags")
}

model ContactMessage {
  id        String        @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  status    MessageStatus @default(UNREAD)
  ipAddress String?
  userAgent String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model Testimonial {
  id            String   @id @default(cuid())
  reviewerName  String
  reviewerTitle String?
  reviewerImage String?
  feedback      String
  published     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Resume {
  id            String   @id @default(cuid())
  title         String
  fileUrl       String
  cloudinaryId  String?
  version       String
  active        Boolean  @default(false)
  downloadCount Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Media {
  id           String    @id @default(cuid())
  publicId     String
  url          String
  secureUrl    String
  resourceType MediaType @default(IMAGE)
  format       String?
  bytes        Int?
  width        Int?
  height       Int?
  alt          String?
  projectId    String?
  project      Project?  @relation("ProjectMedia", fields: [projectId], references: [id], onDelete: SetNull)
  createdAt    DateTime  @default(now())
}

model VisitorAnalytics {
  id        String   @id @default(cuid())
  path      String
  event     String   @default("page_view")
  country   String?
  device    String?
  browser   String?
  ipHash    String?
  metadata  Json?
  createdAt DateTime @default(now())
}

model Category {
  id       String   @id @default(cuid())
  name     String   @unique
  slug     String   @unique
  projects Project[]  @relation("ProjectCategories")
  blogs    Blog[]     @relation("BlogCategories")
  createdAt DateTime @default(now())
}

model Tag {
  id       String   @id @default(cuid())
  name     String   @unique
  slug     String   @unique
  projects Project[] @relation("ProjectTags")
  blogs    Blog[]    @relation("BlogTags")
  createdAt DateTime @default(now())
}

model GitHubCache {
  key       String   @id @unique
  payload   Json
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())
}
